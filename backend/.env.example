# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── OpenRouter (LLM / Vision pipeline) ──────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Nutrition Search APIs ────────────────────────────────────────────────────
DATA_GO_KR_FOOD_API_KEY=
SERPAPI_API_KEY=
CALORIE_NINJA_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Dev default: http://localhost:3000
# Prod: set to the exact Vercel URL, e.g. https://nutritrack.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ─── Environment & Auth ───────────────────────────────────────────────────────
# Set to "development" locally only. Defaults to "production" if unset.
ENVIRONMENT=development
# Set to "true" locally to bypass JWT verification during development.
# The server REFUSES TO START if SKIP_AUTH=true and ENVIRONMENT=production.
SKIP_AUTH=false
